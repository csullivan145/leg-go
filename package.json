{
  "private": true,
  "workspaces": ["packages/shared", "api", "web"],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev -w api",
    "dev:web": "npm run dev -w web",
    "build": "npm run build -w @leg-go/shared && npm run build -w api && npm run build -w web",
    "deploy": "npm run build -w web && npx wrangler deploy",
    "db:generate": "npm run db:generate -w api",
    "db:migrate": "npm run db:migrate -w api"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3",
    "wrangler": "^4.69.0"
  }
}
